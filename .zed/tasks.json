[
  {
    "label": "CMake Configure",
    "command": "cmake",
    "args": ["-B", "build"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "CMake Build (Debug)",
    "command": "cmake",
    "args": ["--build", "build", "--config", "Debug"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "CMake Build (Release)",
    "command": "cmake",
    "args": ["--build", "build", "--config", "Release"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Run Serial (Unix)",
    "command": "./build/upp_sp1",
    "args": ["data/stanice.csv", "data/mereni.csv", "--serial"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Run Parallel (Unix)",
    "command": "./build/upp_sp1",
    "args": ["data/stanice.csv", "data/mereni.csv", "--parallel"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Run Serial (Windows Debug)",
    "command": ".\\build\\Debug\\upp_sp1.exe",
    "args": ["data\\stanice.csv", "data\\mereni.csv", "--serial"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Run Parallel (Windows Debug)",
    "command": ".\\build\\Debug\\upp_sp1.exe",
    "args": ["data\\stanice.csv", "data\\mereni.csv", "--parallel"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Run Serial (Windows Release)",
    "command": ".\\build\\Release\\upp_sp1.exe",
    "args": ["data\\stanice.csv", "data\\mereni.csv", "--serial"],
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Run Parallel (Windows Release)",
    "command": ".\\build\\Release\\upp_sp1.exe",
    "args": ["data\\stanice.csv", "data\\mereni.csv", "--parallel"],
    "cwd": "$ZED_WORKTREE_ROOT"
  }
]
